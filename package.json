{
  "name": "dotnav-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "compile": "npm run compile --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "package:dotnav": "npm run package:vsix --workspace dotnav -- --out ../../dist/dotnav.vsix",
    "package:gitnav": "npm run package:vsix --workspace gitnav -- --out ../../dist/gitnav.vsix",
    "package:all": "npm run package:dotnav && npm run package:gitnav"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.5.4"
  }
}
