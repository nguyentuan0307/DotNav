{
  "name": "rider-like-solution-navigator",
  "displayName": "Rider-like Solution Navigator",
  "description": "A Rider-inspired .NET solution explorer for Visual Studio Code.",
  "version": "0.1.0",
  "publisher": "tuna-ex",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyentuan0307/CodexProject.git"
  },
  "homepage": "https://github.com/nguyentuan0307/CodexProject#readme",
  "bugs": {
    "url": "https://github.com/nguyentuan0307/CodexProject/issues"
  },
  "keywords": [
    "dotnet",
    "csharp",
    "solution",
    "solution explorer",
    "rider"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "ms-dotnettools.csharp"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:csharp",
    "onView:dotnetSolutionNavigator",
    "onView:dotnetSolutionNavigator.runConfigurations",
    "onCommand:dotnetSolutionNavigator.refresh",
    "onCommand:dotnetSolutionNavigator.searchSolutionTree",
    "onCommand:dotnetSolutionNavigator.buildSolution",
    "onCommand:dotnetSolutionNavigator.buildFolderProjects",
    "onCommand:dotnetSolutionNavigator.rebuildSolution",
    "onCommand:dotnetSolutionNavigator.cleanSolution",
    "onCommand:dotnetSolutionNavigator.openWorkspaceFolder",
    "onCommand:dotnetSolutionNavigator.showHistoryForSelection",
    "onCommand:dotnetSolutionNavigator.compareFileWithBranch",
    "onCommand:dotnetSolutionNavigator.compareSelectionWithBranch",
    "onCommand:dotnetSolutionNavigator.formatSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotnetSolutionNavigatorContainer",
          "title": ".NET",
          "icon": "media/dotnet.svg"
        }
      ],
      "panel": [
        {
          "id": "dotnetSolutionNavigatorGitPanel",
          "title": "Git Log",
          "icon": "$(git-commit)"
        }
      ]
    },
    "views": {
      "dotnetSolutionNavigatorContainer": [
        {
          "id": "dotnetSolutionNavigator",
          "name": "Solution"
        },
        {
          "id": "dotnetSolutionNavigator.runConfigurations",
          "name": "Run Configurations"
        }
      ],
      "dotnetSolutionNavigatorGitPanel": [
        {
          "type": "webview",
          "id": "dotnetSolutionNavigator.gitLog",
          "name": "Git Log"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dotnetSolutionNavigator",
        "contents": "No .NET solution or project is open.\n[Open Folder](command:dotnetSolutionNavigator.openWorkspaceFolder)\n[Select Solution](command:dotnetSolutionNavigator.selectSolution)"
      }
    ],
    "commands": [
      {
        "command": "dotnetSolutionNavigator.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "dotnetSolutionNavigator.selectSolution",
        "title": "Select Active Solution",
        "icon": "$(repo)"
      },
      {
        "command": "dotnetSolutionNavigator.selectOpenedFile",
        "title": "Select Opened File",
        "icon": "$(target)"
      },
      {
        "command": "dotnetSolutionNavigator.searchSolutionTree",
        "title": "Filter Solution Tree",
        "icon": "$(search)"
      },
      {
        "command": "dotnetSolutionNavigator.showHistoryForSelection",
        "title": "Show History for Selection",
        "icon": "$(git-commit)"
      },
      {
        "command": "dotnetSolutionNavigator.compareFileWithBranch",
        "title": "Compare File With Branch...",
        "icon": "$(git-compare)"
      },
      {
        "command": "dotnetSolutionNavigator.compareSelectionWithBranch",
        "title": "Compare Selection With Branch...",
        "icon": "$(git-compare)"
      },
      {
        "command": "dotnetSolutionNavigator.formatSelection",
        "title": "Format Selection",
        "icon": "$(symbol-method)"
      },
      {
        "command": "dotnetSolutionNavigator.openItem",
        "title": "Open"
      },
      {
        "command": "dotnetSolutionNavigator.openProjectFile",
        "title": "Open Project File"
      },
      {
        "command": "dotnetSolutionNavigator.openSolutionFile",
        "title": "Open Solution File"
      },
      {
        "command": "dotnetSolutionNavigator.openSolutionTerminal",
        "title": "Open Solution Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "dotnetSolutionNavigator.buildProject",
        "title": "Build"
      },
      {
        "command": "dotnetSolutionNavigator.buildFolderProjects",
        "title": "Build Projects in Folder",
        "icon": "$(tools)"
      },
      {
        "command": "dotnetSolutionNavigator.rebuildProject",
        "title": "Rebuild"
      },
      {
        "command": "dotnetSolutionNavigator.buildSolution",
        "title": "Build Solution",
        "icon": "$(tools)"
      },
      {
        "command": "dotnetSolutionNavigator.rebuildSolution",
        "title": "Rebuild Solution",
        "icon": "$(sync)"
      },
      {
        "command": "dotnetSolutionNavigator.cleanSolution",
        "title": "Clean Solution",
        "icon": "$(clear-all)"
      },
      {
        "command": "dotnetSolutionNavigator.openWorkspaceFolder",
        "title": "Open Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "dotnetSolutionNavigator.runProject",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "dotnetSolutionNavigator.debugProject",
        "title": "Debug",
        "icon": "$(debug-alt)"
      },
      {
        "command": "dotnetSolutionNavigator.testProject",
        "title": "Test"
      },
      {
        "command": "dotnetSolutionNavigator.cleanProject",
        "title": "Clean"
      },
      {
        "command": "dotnetSolutionNavigator.setStartupProject",
        "title": "Set as Startup Project"
      },
      {
        "command": "dotnetSolutionNavigator.openTerminalHere",
        "title": "Open Terminal Here"
      },
      {
        "command": "dotnetSolutionNavigator.toggleProjectFiles",
        "title": "Toggle Project Files",
        "icon": "$(eye)"
      },
      {
        "command": "dotnetSolutionNavigator.toggleFileNesting",
        "title": "Toggle File Nesting",
        "icon": "$(list-tree)"
      },
      {
        "command": "dotnetSolutionNavigator.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dotnetSolutionNavigator.addClass",
        "title": "Add: New Class"
      },
      {
        "command": "dotnetSolutionNavigator.addInterface",
        "title": "Add: New Interface"
      },
      {
        "command": "dotnetSolutionNavigator.addRecord",
        "title": "Add: New Record"
      },
      {
        "command": "dotnetSolutionNavigator.addEnum",
        "title": "Add: New Enum"
      },
      {
        "command": "dotnetSolutionNavigator.addFile",
        "title": "Add: New File"
      },
      {
        "command": "dotnetSolutionNavigator.addFolder",
        "title": "Add: New Folder"
      },
      {
        "command": "dotnetSolutionNavigator.addExistingItem",
        "title": "Add: Existing Item..."
      },
      {
        "command": "dotnetSolutionNavigator.renameItem",
        "title": "Rename"
      },
      {
        "command": "dotnetSolutionNavigator.moveItem",
        "title": "Move To..."
      },
      {
        "command": "dotnetSolutionNavigator.deleteItem",
        "title": "Delete"
      },
      {
        "command": "dotnetSolutionNavigator.copyPath",
        "title": ".NET: Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "dotnetSolutionNavigator.copyRelativePath",
        "title": ".NET: Copy Relative Path",
        "icon": "$(files)"
      },
      {
        "command": "dotnetSolutionNavigator.revealInOs",
        "title": ".NET: Reveal in File Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "dotnetSolutionNavigator.stopProject",
        "title": "Stop",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnetSolutionNavigator.stopAll",
        "title": "Stop All",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnetSolutionNavigator.stopActiveConfig",
        "title": "Stop Active Configuration",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnetSolutionNavigator.showRunOutput",
        "title": "Show Run Output",
        "icon": "$(output)"
      },
      {
        "command": "dotnetSolutionNavigator.stopConfigNode",
        "title": "Stop Configuration",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnetSolutionNavigator.selectRunConfig",
        "title": "Select Run Configuration",
        "icon": "$(rocket)"
      },
      {
        "command": "dotnetSolutionNavigator.addRunConfig",
        "title": "Add Run Configuration",
        "icon": "$(add)"
      },
      {
        "command": "dotnetSolutionNavigator.renameRunConfig",
        "title": "Rename Configuration"
      },
      {
        "command": "dotnetSolutionNavigator.removeRunConfig",
        "title": "Remove Run Configuration",
        "icon": "$(close)"
      },
      {
        "command": "dotnetSolutionNavigator.runActiveConfig",
        "title": "Run Active Configuration",
        "icon": "$(play)"
      },
      {
        "command": "dotnetSolutionNavigator.debugActiveConfig",
        "title": "Debug Active Configuration",
        "icon": "$(bug)"
      },
      {
        "command": "dotnetSolutionNavigator.buildActiveConfig",
        "title": "Build Active Configuration",
        "icon": "$(tools)"
      },
      {
        "command": "dotnetSolutionNavigator.newCompound",
        "title": "New Compound Configuration"
      },
      {
        "command": "dotnetSolutionNavigator.deleteCompound",
        "title": "Delete Compound Configuration"
      },
      {
        "command": "dotnetSolutionNavigator.setActiveConfig",
        "title": "Set as Active"
      },
      {
        "command": "dotnetSolutionNavigator.runConfigNode",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "dotnetSolutionNavigator.debugConfigNode",
        "title": "Debug",
        "icon": "$(bug)"
      }
    ],
    "submenus": [
      {
        "id": "dotnetSolutionNavigator.git",
        "label": "Git"
      },
      {
        "id": "dotnetSolutionNavigator.add",
        "label": "Add"
      }
    ],
    "keybindings": [
      {
        "command": "dotnetSolutionNavigator.renameItem",
        "key": "f2",
        "when": "focusedView == dotnetSolutionNavigator"
      },
      {
        "command": "dotnetSolutionNavigator.deleteItem",
        "key": "delete",
        "when": "focusedView == dotnetSolutionNavigator"
      },
      {
        "command": "dotnetSolutionNavigator.formatSelection",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus && editorLangId == csharp"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "dotnetSolutionNavigator.formatSelection",
          "when": "editorLangId == csharp",
          "group": "6_dotnetNavigator@0"
        },
        {
          "submenu": "dotnetSolutionNavigator.git",
          "group": "6_dotnetNavigator@1"
        }
      ],
      "view/title": [
        {
          "command": "dotnetSolutionNavigator.addRunConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations",
          "group": "navigation@0"
        },
        {
          "command": "dotnetSolutionNavigator.selectOpenedFile",
          "when": "view == dotnetSolutionNavigator",
          "group": "navigation@0"
        },
        {
          "command": "dotnetSolutionNavigator.searchSolutionTree",
          "when": "view == dotnetSolutionNavigator",
          "group": "navigation@0.5"
        },
        {
          "command": "dotnetSolutionNavigator.runActiveConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && !dotnetSolutionNavigator.activeConfigBusy",
          "group": "navigation@1"
        },
        {
          "command": "dotnetSolutionNavigator.debugActiveConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && !dotnetSolutionNavigator.activeConfigBusy",
          "group": "navigation@2"
        },
        {
          "command": "dotnetSolutionNavigator.stopActiveConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && dotnetSolutionNavigator.activeConfigBusy",
          "group": "navigation@3"
        },
        {
          "command": "dotnetSolutionNavigator.stopAll",
          "when": "view == dotnetSolutionNavigator && dotnetSolutionNavigator.hasRunningProcesses",
          "group": "navigation@3"
        },
        {
          "command": "dotnetSolutionNavigator.refresh",
          "when": "view == dotnetSolutionNavigator",
          "group": "navigation@4"
        },
        {
          "command": "dotnetSolutionNavigator.selectSolution",
          "when": "view == dotnetSolutionNavigator",
          "group": "2_view@3"
        },
        {
          "command": "dotnetSolutionNavigator.selectRunConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations",
          "group": "1_config@1"
        },
        {
          "command": "dotnetSolutionNavigator.buildActiveConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && !dotnetSolutionNavigator.activeConfigBusy",
          "group": "1_config@2"
        },
        {
          "command": "dotnetSolutionNavigator.toggleProjectFiles",
          "when": "view == dotnetSolutionNavigator",
          "group": "2_view@1"
        },
        {
          "command": "dotnetSolutionNavigator.toggleFileNesting",
          "when": "view == dotnetSolutionNavigator",
          "group": "2_view@2"
        },
        {
          "command": "dotnetSolutionNavigator.openSettings",
          "when": "view == dotnetSolutionNavigator",
          "group": "3_settings@1"
        }
      ],
      "view/item/context": [
        {
          "command": "dotnetSolutionNavigator.runProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "inline@1"
        },
        {
          "command": "dotnetSolutionNavigator.debugProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "inline@2"
        },
        {
          "command": "dotnetSolutionNavigator.stopProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "inline@1"
        },
        {
          "command": "dotnetSolutionNavigator.buildSolution",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "solution@1"
        },
        {
          "command": "dotnetSolutionNavigator.rebuildSolution",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "solution@2"
        },
        {
          "command": "dotnetSolutionNavigator.cleanSolution",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "solution@3"
        },
        {
          "command": "dotnetSolutionNavigator.openSolutionFile",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "navigation@1"
        },
        {
          "command": "dotnetSolutionNavigator.openSolutionTerminal",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "terminal@1"
        },
        {
          "command": "dotnetSolutionNavigator.selectSolution",
          "when": "view == dotnetSolutionNavigator && viewItem == solution",
          "group": "navigation@2"
        },
        {
          "submenu": "dotnetSolutionNavigator.add",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /folder|project/",
          "group": "6_add@0"
        },
        {
          "command": "dotnetSolutionNavigator.openItem",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file/",
          "group": "navigation@1"
        },
        {
          "command": "dotnetSolutionNavigator.renameItem",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder/",
          "group": "edit@1"
        },
        {
          "command": "dotnetSolutionNavigator.moveItem",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder/",
          "group": "edit@2"
        },
        {
          "command": "dotnetSolutionNavigator.deleteItem",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder/",
          "group": "edit@3"
        },
        {
          "command": "dotnetSolutionNavigator.copyPath",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder|project/",
          "group": "7_copy@1"
        },
        {
          "command": "dotnetSolutionNavigator.copyRelativePath",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder|project/",
          "group": "7_copy@2"
        },
        {
          "command": "dotnetSolutionNavigator.revealInOs",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /file|folder|project/",
          "group": "7_copy@3"
        },
        {
          "command": "dotnetSolutionNavigator.openProjectFile",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/",
          "group": "4_navigation@1"
        },
        {
          "command": "dotnetSolutionNavigator.setStartupProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/",
          "group": "3_project@1"
        },
        {
          "command": "dotnetSolutionNavigator.runProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "1_run@1"
        },
        {
          "command": "dotnetSolutionNavigator.debugProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "1_run@2"
        },
        {
          "command": "dotnetSolutionNavigator.buildProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/",
          "group": "2_build@1"
        },
        {
          "command": "dotnetSolutionNavigator.buildFolderProjects",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /folder|solutionFolder/",
          "group": "2_build@1"
        },
        {
          "command": "dotnetSolutionNavigator.rebuildProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/",
          "group": "2_build@2"
        },
        {
          "command": "dotnetSolutionNavigator.stopProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "1_run@3"
        },
        {
          "command": "dotnetSolutionNavigator.testProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/ && viewItem =~ /test/",
          "group": "2_build@4"
        },
        {
          "command": "dotnetSolutionNavigator.cleanProject",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /project/",
          "group": "2_build@3"
        },
        {
          "command": "dotnetSolutionNavigator.openTerminalHere",
          "when": "view == dotnetSolutionNavigator && viewItem =~ /folder|project/",
          "group": "5_terminal@1"
        },
        {
          "command": "dotnetSolutionNavigator.runConfigNode",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@1"
        },
        {
          "command": "dotnetSolutionNavigator.debugConfigNode",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@2"
        },
        {
          "command": "dotnetSolutionNavigator.stopConfigNode",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "inline@1"
        },
        {
          "command": "dotnetSolutionNavigator.showRunOutput",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && viewItem =~ /busy/",
          "group": "inline@2"
        },
        {
          "command": "dotnetSolutionNavigator.removeRunConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@3"
        },
        {
          "command": "dotnetSolutionNavigator.setActiveConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/",
          "group": "cfg@1"
        },
        {
          "command": "dotnetSolutionNavigator.renameRunConfig",
          "when": "view == dotnetSolutionNavigator.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "cfg@2"
        }
      ],
      "dotnetSolutionNavigator.git": [
        {
          "command": "dotnetSolutionNavigator.compareFileWithBranch",
          "group": "compare@1"
        },
        {
          "command": "dotnetSolutionNavigator.compareSelectionWithBranch",
          "when": "editorHasSelection",
          "group": "compare@2"
        },
        {
          "command": "dotnetSolutionNavigator.showHistoryForSelection",
          "when": "editorHasSelection",
          "group": "history@1"
        }
      ],
      "dotnetSolutionNavigator.add": [
        {
          "command": "dotnetSolutionNavigator.addClass",
          "group": "1_new@1"
        },
        {
          "command": "dotnetSolutionNavigator.addInterface",
          "group": "1_new@2"
        },
        {
          "command": "dotnetSolutionNavigator.addRecord",
          "group": "1_new@3"
        },
        {
          "command": "dotnetSolutionNavigator.addEnum",
          "group": "1_new@4"
        },
        {
          "command": "dotnetSolutionNavigator.addFile",
          "group": "2_file@1"
        },
        {
          "command": "dotnetSolutionNavigator.addFolder",
          "group": "2_file@2"
        },
        {
          "command": "dotnetSolutionNavigator.addExistingItem",
          "group": "3_existing@1"
        }
      ]
    },
    "configuration": {
      "title": ".NET Solution Navigator",
      "properties": {
        "dotnetSolutionNavigator.hiddenFolders": {
          "type": "array",
          "default": [
            "bin",
            "obj",
            ".vs",
            ".vscode",
            ".git",
            ".idea",
            ".config",
            "node_modules",
            "TestResults",
            "coverage",
            "artifacts",
            "packages"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names hidden from the solution tree."
        },
        "dotnetSolutionNavigator.hiddenFiles": {
          "type": "array",
          "default": [
            "*.user",
            "*.suo",
            "*.cache"
          ],
          "items": {
            "type": "string"
          },
          "description": "File globs hidden from the solution tree."
        },
        "dotnetSolutionNavigator.showDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Show project and NuGet dependencies under each project."
        },
        "dotnetSolutionNavigator.showProjectFiles": {
          "type": "boolean",
          "default": true,
          "description": "Show project files such as .csproj, .fsproj, .vbproj, and .dcproj inside each project node."
        },
        "dotnetSolutionNavigator.buildBeforeRun": {
          "type": "boolean",
          "default": true,
          "description": "Build the selected project before running or debugging it."
        },
        "dotnetSolutionNavigator.buildConfiguration": {
          "type": "string",
          "enum": [
            "Debug",
            "Release"
          ],
          "default": "Debug",
          "description": "Build configuration used when running or debugging projects."
        },
        "dotnetSolutionNavigator.buildTimeoutSeconds": {
          "type": "number",
          "default": 600,
          "minimum": 1,
          "description": "Maximum time in seconds to wait for a build before marking the run as failed."
        },
        "dotnetSolutionNavigator.startTimeoutSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Maximum time in seconds to wait for a debug or run session to start."
        },
        "dotnetSolutionNavigator.forceKillTaskOnStopTimeout": {
          "type": "boolean",
          "default": true,
          "description": "Force-kill the tracked task PID after Stop times out. On Windows this kills the owned process tree."
        },
        "dotnetSolutionNavigator.iconMode": {
          "type": "string",
          "enum": [
            "auto",
            "rider",
            "theme",
            "minimal"
          ],
          "default": "auto",
          "description": "Icon style used by the .NET solution tree. Auto combines Rider project/special-folder icons with the active file icon theme."
        },
        "dotnetSolutionNavigator.enableFileNesting": {
          "type": "boolean",
          "default": true,
          "description": "Nest related files under parent files in the .NET solution tree."
        },
        "dotnetSolutionNavigator.alwaysSelectOpenedFile": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reveal the active editor file in the .NET solution tree."
        },
        "dotnetSolutionNavigator.gitHistoryMaxCommits": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Maximum commits returned by Show History for Selection."
        },
        "dotnetSolutionNavigator.gitLog.protectedBranches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "main",
            "master",
            "develop",
            "release/*"
          ],
          "description": "Branch name patterns on which history-rewriting Git Log actions are blocked."
        },
        "dotnetSolutionNavigator.gitLog.autoFetch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically fetch repositories while the Git Log view is active."
        },
        "dotnetSolutionNavigator.gitLog.autoFetchMinutes": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Interval in minutes between automatic fetch operations."
        },
        "dotnetSolutionNavigator.format.normalizeIndentWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "Normalize leading indentation to the active indentation unit before applying C# house-style passes."
        },
        "dotnetSolutionNavigator.format.enableLeadingComma": {
          "type": "boolean",
          "default": true,
          "description": "Format multiline C# parameter and argument lists with leading commas."
        },
        "dotnetSolutionNavigator.format.wrapColumn": {
          "type": "number",
          "default": 120,
          "minimum": 40,
          "description": "Fallback line width for C# wrapping. A matching .editorconfig max_line_length takes precedence."
        },
        "dotnetSolutionNavigator.format.leadingCommaWrapStyle": {
          "type": "string",
          "enum": [
            "wrapIfLong",
            "chopAlways",
            "keep"
          ],
          "default": "wrapIfLong",
          "description": "Controls wrapping of single-line C# parameter and argument lists; existing multiline leading commas are always normalized."
        },
        "dotnetSolutionNavigator.format.enableFluentChainWrap": {
          "type": "boolean",
          "default": true,
          "description": "Normalize indentation for multiline fluent and LINQ chains."
        },
        "dotnetSolutionNavigator.format.fluentChainMinSegments": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Minimum number of dot-prefixed continuation lines before they are aligned to the same indentation level."
        },
        "dotnetSolutionNavigator.format.enableBlankLineRules": {
          "type": "boolean",
          "default": true,
          "description": "Collapse repeated blank lines and remove blank lines immediately inside braces."
        },
        "dotnetSolutionNavigator.format.expandToEnclosingMember": {
          "type": "boolean",
          "default": false,
          "description": "Expand Format Selection to the enclosing C# member. Disabled by default so formatting only changes the selected lines."
        },
        "dotnetSolutionNavigator.fileNestingRules": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "parentPattern": {
                "type": "string"
              },
              "childPattern": {
                "type": "string"
              }
            },
            "required": [
              "parentPattern",
              "childPattern"
            ]
          },
          "description": "Additional file nesting rules. Use ${base} in parentPattern and childPattern."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "vsce package",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.92.0",
