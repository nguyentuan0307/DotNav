{
  "name": "dotnav",
  "displayName": "DotNav: .NET Solution Explorer",
  "description": "A focused .NET workspace for VS Code with solution navigation, run configurations, Git workflows, and C# formatting.",
  "version": "0.8.2",
  "publisher": "tuna-ex",
  "author": "Tuan Nguyen",
  "icon": "media/icon.png",
  "license": "MIT",
  "galleryBanner": {
    "color": "#512BD4",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyentuan0307/DotNav.git",
    "directory": "extensions/dotnav"
  },
  "homepage": "https://github.com/nguyentuan0307/DotNav#readme",
  "bugs": {
    "url": "https://github.com/nguyentuan0307/DotNav/issues"
  },
  "keywords": [
    "dotnav",
    "dotnet",
    "csharp",
    "solution",
    "solution explorer",
    "msbuild",
    "git",
    "run configurations"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Formatters",
    "Other"
  ],
  "extensionDependencies": [
    "ms-dotnettools.csharp",
    "tuna-ex.gitnav-workflows"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:csharp",
    "onView:dotnav",
    "onView:dotnav.runConfigurations",
    "onCommand:dotnav.refresh",
    "onCommand:dotnav.addPackage",
    "onCommand:dotnav.updatePackage",
    "onCommand:dotnav.removePackage",
    "onCommand:dotnav.restorePackages",
    "onCommand:dotnav.checkOutdated",
    "onCommand:dotnav.addProjectReference",
    "onCommand:dotnav.removeProjectReference",
    "onCommand:dotnav.searchSolutionTree",
    "onCommand:dotnav.buildSolution",
    "onCommand:dotnav.buildFolderProjects",
    "onCommand:dotnav.rebuildSolution",
    "onCommand:dotnav.cleanSolution",
    "onCommand:dotnav.openWorkspaceFolder",
    "onCommand:dotnav.formatSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotnavContainer",
          "title": ".NET",
          "icon": "media/dotnet.svg"
        }
      ]
    },
    "views": {
      "dotnavContainer": [
        {
          "id": "dotnav",
          "name": "Solution"
        },
        {
          "id": "dotnav.runConfigurations",
          "name": "Run Configurations"
        },
        {
          "id": "dotnav.efCore",
          "name": "EF Core",
          "when": "dotnav.ef.hasProjects",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dotnav",
        "contents": "No .NET solution or project is open.\n[Open Folder](command:dotnav.openWorkspaceFolder)\n[Select Solution](command:dotnav.selectSolution)"
      }
    ],
    "commands": [
      {
        "command": "dotnav.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "dotnav.addPackage",
        "title": "Add NuGet Package...",
        "icon": "$(add)"
      },
      {
        "command": "dotnav.updatePackage",
        "title": "Update NuGet Package...",
        "icon": "$(arrow-up)"
      },
      {
        "command": "dotnav.removePackage",
        "title": "Remove NuGet Package",
        "icon": "$(close)"
      },
      {
        "command": "dotnav.restorePackages",
        "title": "Restore NuGet Packages",
        "icon": "$(sync)"
      },
      {
        "command": "dotnav.checkOutdated",
        "title": "Check for Outdated NuGet Packages",
        "icon": "$(cloud-download)"
      },
      {
        "command": "dotnav.addProjectReference",
        "title": "Add Project Reference",
        "icon": "$(add)"
      },
      {
        "command": "dotnav.removeProjectReference",
        "title": "Remove Reference",
        "icon": "$(close)"
      },
      {
        "command": "dotnav.selectSolution",
        "title": "Select Active Solution",
        "icon": "$(repo)"
      },
      {
        "command": "dotnav.selectOpenedFile",
        "title": "Select Opened File",
        "icon": "$(target)"
      },
      {
        "command": "dotnav.searchSolutionTree",
        "title": "Filter Solution Tree",
        "icon": "$(search)"
      },
      {
        "command": "dotnav.formatSelection",
        "title": "Format Selection",
        "icon": "$(symbol-method)"
      },
      {
        "command": "dotnav.openItem",
        "title": "Open"
      },
      {
        "command": "dotnav.openProjectFile",
        "title": "Open Project File"
      },
      {
        "command": "dotnav.openSolutionFile",
        "title": "Open Solution File"
      },
      {
        "command": "dotnav.openSolutionTerminal",
        "title": "Open Solution Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "dotnav.buildProject",
        "title": "Build"
      },
      {
        "command": "dotnav.buildFolderProjects",
        "title": "Build Projects in Folder",
        "icon": "$(tools)"
      },
      {
        "command": "dotnav.rebuildProject",
        "title": "Rebuild"
      },
      {
        "command": "dotnav.buildSolution",
        "title": "Build Solution",
        "icon": "$(tools)"
      },
      {
        "command": "dotnav.rebuildSolution",
        "title": "Rebuild Solution",
        "icon": "$(sync)"
      },
      {
        "command": "dotnav.cleanSolution",
        "title": "Clean Solution",
        "icon": "$(clear-all)"
      },
      {
        "command": "dotnav.openWorkspaceFolder",
        "title": "Open Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "dotnav.runProject",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "dotnav.debugProject",
        "title": "Debug",
        "icon": "$(debug-alt)"
      },
      {
        "command": "dotnav.testProject",
        "title": "Test"
      },
      {
        "command": "dotnav.cleanProject",
        "title": "Clean"
      },
      {
        "command": "dotnav.setStartupProject",
        "title": "Set as Startup Project"
      },
      {
        "command": "dotnav.openTerminalHere",
        "title": "Open Terminal Here"
      },
      {
        "command": "dotnav.toggleProjectFiles",
        "title": "Toggle Project Files",
        "icon": "$(eye)"
      },
      {
        "command": "dotnav.toggleFileNesting",
        "title": "Toggle File Nesting",
        "icon": "$(list-tree)"
      },
      {
        "command": "dotnav.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dotnav.addClass",
        "title": "Class"
      },
      {
        "command": "dotnav.addInterface",
        "title": "Interface"
      },
      {
        "command": "dotnav.addRecord",
        "title": "Record"
      },
      {
        "command": "dotnav.addEnum",
        "title": "Enum"
      },
      {
        "command": "dotnav.addFile",
        "title": "File"
      },
      {
        "command": "dotnav.addFolder",
        "title": "Folder"
      },
      {
        "command": "dotnav.addExistingItem",
        "title": "Existing Item..."
      },
      {
        "command": "dotnav.renameItem",
        "title": "Rename"
      },
      {
        "command": "dotnav.moveItem",
        "title": "Move To..."
      },
      {
        "command": "dotnav.deleteItem",
        "title": "Delete"
      },
      {
        "command": "dotnav.copyPath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "dotnav.copyRelativePath",
        "title": "Copy Relative Path",
        "icon": "$(files)"
      },
      {
        "command": "dotnav.revealInOs",
        "title": "Reveal in File Explorer",
        "icon": "$(folder-opened)"
      },
      {
        "command": "dotnav.stopProject",
        "title": "Stop",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnav.stopAll",
        "title": "Stop All",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnav.stopActiveConfig",
        "title": "Stop Active Configuration",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnav.showRunOutput",
        "title": "Show Run Output",
        "icon": "$(output)"
      },
      {
        "command": "dotnav.stopConfigNode",
        "title": "Stop Configuration",
        "icon": "$(stop-circle)"
      },
      {
        "command": "dotnav.selectRunConfig",
        "title": "Select Run Configuration",
        "icon": "$(rocket)"
      },
      {
        "command": "dotnav.addRunConfig",
        "title": "Add Run Configuration",
        "icon": "$(add)"
      },
      {
        "command": "dotnav.renameRunConfig",
        "title": "Rename Configuration"
      },
      {
        "command": "dotnav.removeRunConfig",
        "title": "Remove Run Configuration",
        "icon": "$(close)"
      },
      {
        "command": "dotnav.runActiveConfig",
        "title": "Run Active Configuration",
        "icon": "$(play)"
      },
      {
        "command": "dotnav.debugActiveConfig",
        "title": "Debug Active Configuration",
        "icon": "$(bug)"
      },
      {
        "command": "dotnav.buildActiveConfig",
        "title": "Build Active Configuration",
        "icon": "$(tools)"
      },
      {
        "command": "dotnav.newCompound",
        "title": "New Compound Configuration"
      },
      {
        "command": "dotnav.deleteCompound",
        "title": "Delete Compound Configuration"
      },
      {
        "command": "dotnav.setActiveConfig",
        "title": "Set as Active"
      },
      {
        "command": "dotnav.runConfigNode",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "dotnav.debugConfigNode",
        "title": "Debug",
        "icon": "$(bug)"
      },
      {
        "command": "dotnav.ef.addMigration",
        "title": "Add Migration...",
        "category": "EF Core",
        "icon": "$(add)"
      },
      {
        "command": "dotnav.ef.removeLastMigration",
        "title": "Remove Last Migration",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.listMigrations",
        "title": "List Migrations",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.updateDatabase",
        "title": "Update Database",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.updateDatabaseTo",
        "title": "Update Database to Migration...",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.updateDatabaseToThis",
        "title": "Update Database to This Migration",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.rollbackDatabaseToThis",
        "title": "Rollback Database to This Migration",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.generateScript",
        "title": "Generate SQL Script...",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.generateScriptFromThis",
        "title": "Generate Script from This Migration...",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.dropDatabase",
        "title": "Drop Database...",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.dbContextInfo",
        "title": "DbContext Info",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.installTool",
        "title": "Install/Update dotnet-ef Tool",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.selectStartupProject",
        "title": "Select Startup Project...",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.refresh",
        "title": "Refresh",
        "category": "EF Core",
        "icon": "$(refresh)"
      },
      {
        "command": "dotnav.ef.openSettings",
        "title": "EF Core Settings",
        "category": "EF Core",
        "icon": "$(gear)"
      },
      {
        "command": "dotnav.ef.showOutput",
        "title": "Show Output",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.openMigrationFile",
        "title": "Open Migration File",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.copyMigrationName",
        "title": "Copy Migration Name",
        "category": "EF Core"
      },
      {
        "command": "dotnav.ef.openCsproj",
        "title": "Open Project File",
        "category": "EF Core"
      }
    ],
    "submenus": [
      {
        "id": "dotnav.add",
        "label": "Add"
      },
      {
        "id": "dotnav.project",
        "label": "Project"
      },
      {
        "id": "dotnav.copy",
        "label": "Copy"
      }
    ],
    "keybindings": [
      {
        "command": "dotnav.renameItem",
        "key": "f2",
        "when": "focusedView == dotnav"
      },
      {
        "command": "dotnav.deleteItem",
        "key": "delete",
        "when": "focusedView == dotnav"
      },
      {
        "command": "dotnav.formatSelection",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus && editorLangId == csharp"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "dotnav.formatSelection",
          "when": "editorLangId == csharp",
          "group": "6_dotnav@0"
        }
      ],
      "view/title": [
        {
          "command": "dotnav.addRunConfig",
          "when": "view == dotnav.runConfigurations",
          "group": "navigation@0"
        },
        {
          "command": "dotnav.selectOpenedFile",
          "when": "view == dotnav",
          "group": "navigation@0"
        },
        {
          "command": "dotnav.searchSolutionTree",
          "when": "view == dotnav",
          "group": "navigation@0.5"
        },
        {
          "command": "dotnav.runActiveConfig",
          "when": "view == dotnav.runConfigurations && !dotnav.activeConfigBusy",
          "group": "navigation@1"
        },
        {
          "command": "dotnav.debugActiveConfig",
          "when": "view == dotnav.runConfigurations && !dotnav.activeConfigBusy",
          "group": "navigation@2"
        },
        {
          "command": "dotnav.stopActiveConfig",
          "when": "view == dotnav.runConfigurations && dotnav.activeConfigBusy",
          "group": "navigation@3"
        },
        {
          "command": "dotnav.stopAll",
          "when": "view == dotnav && dotnav.hasRunningProcesses",
          "group": "navigation@3"
        },
        {
          "command": "dotnav.refresh",
          "when": "view == dotnav",
          "group": "navigation@4"
        },
        {
          "command": "dotnav.checkOutdated",
          "when": "view == dotnav",
          "group": "navigation@3.5"
        },
        {
          "command": "dotnav.selectSolution",
          "when": "view == dotnav",
          "group": "2_view@3"
        },
        {
          "command": "dotnav.selectRunConfig",
          "when": "view == dotnav.runConfigurations",
          "group": "1_config@1"
        },
        {
          "command": "dotnav.buildActiveConfig",
          "when": "view == dotnav.runConfigurations && !dotnav.activeConfigBusy",
          "group": "1_config@2"
        },
        {
          "command": "dotnav.toggleProjectFiles",
          "when": "view == dotnav",
          "group": "2_view@1"
        },
        {
          "command": "dotnav.toggleFileNesting",
          "when": "view == dotnav",
          "group": "2_view@2"
        },
        {
          "command": "dotnav.openSettings",
          "when": "view == dotnav",
          "group": "3_settings@1"
        },
        {
          "command": "dotnav.ef.addMigration",
          "when": "view == dotnav.efCore",
          "group": "navigation@1"
        },
        {
          "command": "dotnav.ef.refresh",
          "when": "view == dotnav.efCore",
          "group": "navigation@2"
        },
        {
          "command": "dotnav.ef.openSettings",
          "when": "view == dotnav.efCore",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "dotnav.addPackage",
          "when": "view == dotnav && (viewItem == dependencies || viewItem == packageReferences)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.updatePackage",
          "when": "view == dotnav && viewItem =~ /^packageReference(\\s|$)/ && viewItem =~ /outdated/",
          "group": "inline@1"
        },
        {
          "command": "dotnav.removePackage",
          "when": "view == dotnav && viewItem =~ /^packageReference(\\s|$)/",
          "group": "inline@2"
        },
        {
          "command": "dotnav.checkOutdated",
          "when": "view == dotnav && (viewItem == solution || viewItem =~ /^project(\\s|$)/)",
          "group": "inline@3"
        },
        {
          "command": "dotnav.addProjectReference",
          "when": "view == dotnav && (viewItem == dependencies || viewItem == projectReferences)",
          "group": "inline@2"
        },
        {
          "command": "dotnav.removeProjectReference",
          "when": "view == dotnav && viewItem == projectReference",
          "group": "inline@1"
        },
        {
          "command": "dotnav.addPackage",
          "when": "view == dotnav && (viewItem =~ /^project(\\s|$)/ || viewItem == dependencies || viewItem == packageReferences)",
          "group": "8_nuget@1"
        },
        {
          "command": "dotnav.updatePackage",
          "when": "view == dotnav && viewItem =~ /^packageReference(\\s|$)/",
          "group": "8_nuget@2"
        },
        {
          "command": "dotnav.removePackage",
          "when": "view == dotnav && viewItem =~ /^packageReference(\\s|$)/",
          "group": "8_nuget@3"
        },
        {
          "command": "dotnav.restorePackages",
          "when": "view == dotnav && (viewItem == solution || viewItem =~ /^project(\\s|$)/)",
          "group": "8_nuget@4"
        },
        {
          "command": "dotnav.checkOutdated",
          "when": "view == dotnav && (viewItem == solution || viewItem =~ /^project(\\s|$)/)",
          "group": "8_nuget@5"
        },
        {
          "command": "dotnav.addProjectReference",
          "when": "view == dotnav && (viewItem =~ /^project(\\s|$)/ || viewItem == dependencies || viewItem == projectReferences)",
          "group": "9_reference@1"
        },
        {
          "command": "dotnav.removeProjectReference",
          "when": "view == dotnav && viewItem == projectReference",
          "group": "9_reference@2"
        },
        {
          "command": "dotnav.runProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.debugProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "inline@2"
        },
        {
          "command": "dotnav.stopProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.buildSolution",
          "when": "view == dotnav && viewItem == solution",
          "group": "solution@1"
        },
        {
          "command": "dotnav.rebuildSolution",
          "when": "view == dotnav && viewItem == solution",
          "group": "solution@2"
        },
        {
          "command": "dotnav.cleanSolution",
          "when": "view == dotnav && viewItem == solution",
          "group": "solution@3"
        },
        {
          "command": "dotnav.openSolutionFile",
          "when": "view == dotnav && viewItem == solution",
          "group": "navigation@1"
        },
        {
          "command": "dotnav.openSolutionTerminal",
          "when": "view == dotnav && viewItem == solution",
          "group": "terminal@1"
        },
        {
          "command": "dotnav.selectSolution",
          "when": "view == dotnav && viewItem == solution",
          "group": "navigation@2"
        },
        {
          "submenu": "dotnav.add",
          "when": "view == dotnav && viewItem =~ /folder|project/",
          "group": "3_add@1"
        },
        {
          "command": "dotnav.openItem",
          "when": "view == dotnav && viewItem =~ /file/",
          "group": "navigation@1"
        },
        {
          "command": "dotnav.renameItem",
          "when": "view == dotnav && viewItem =~ /file|folder/",
          "group": "edit@1"
        },
        {
          "command": "dotnav.moveItem",
          "when": "view == dotnav && viewItem =~ /file|folder/",
          "group": "edit@2"
        },
        {
          "command": "dotnav.deleteItem",
          "when": "view == dotnav && viewItem =~ /file|folder/",
          "group": "edit@3"
        },
        {
          "submenu": "dotnav.copy",
          "when": "view == dotnav && viewItem =~ /file|folder|project/",
          "group": "7_copy@1"
        },
        {
          "command": "dotnav.revealInOs",
          "when": "view == dotnav && viewItem =~ /file|folder/ && !(viewItem =~ /project/)",
          "group": "7_copy@2"
        },
        {
          "submenu": "dotnav.project",
          "when": "view == dotnav && viewItem =~ /project/",
          "group": "4_project@1"
        },
        {
          "command": "dotnav.runProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "1_run@1"
        },
        {
          "command": "dotnav.debugProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /runnable/ && !(viewItem =~ /busy/)",
          "group": "1_run@2"
        },
        {
          "command": "dotnav.buildProject",
          "when": "view == dotnav && viewItem =~ /project/",
          "group": "2_build@1"
        },
        {
          "command": "dotnav.buildFolderProjects",
          "when": "view == dotnav && viewItem =~ /folder|solutionFolder/",
          "group": "2_build@1"
        },
        {
          "command": "dotnav.rebuildProject",
          "when": "view == dotnav && viewItem =~ /project/",
          "group": "2_build@2"
        },
        {
          "command": "dotnav.stopProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "1_run@3"
        },
        {
          "command": "dotnav.testProject",
          "when": "view == dotnav && viewItem =~ /project/ && viewItem =~ /test/",
          "group": "2_build@4"
        },
        {
          "command": "dotnav.cleanProject",
          "when": "view == dotnav && viewItem =~ /project/",
          "group": "2_build@3"
        },
        {
          "command": "dotnav.openTerminalHere",
          "when": "view == dotnav && viewItem =~ /folder/ && !(viewItem =~ /project/)",
          "group": "5_terminal@1"
        },
        {
          "command": "dotnav.runConfigNode",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.debugConfigNode",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@2"
        },
        {
          "command": "dotnav.stopConfigNode",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && viewItem =~ /busy/ && !(viewItem =~ /stopping/)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.showRunOutput",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && viewItem =~ /busy/",
          "group": "inline@2"
        },
        {
          "command": "dotnav.removeRunConfig",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "inline@3"
        },
        {
          "command": "dotnav.setActiveConfig",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/",
          "group": "cfg@1"
        },
        {
          "command": "dotnav.renameRunConfig",
          "when": "view == dotnav.runConfigurations && viewItem =~ /runConfig/ && !(viewItem =~ /busy/)",
          "group": "cfg@2"
        },
        {
          "command": "dotnav.ef.addMigration",
          "when": "view == dotnav.efCore && (viewItem == efProject || viewItem == efContext)",
          "group": "inline@1"
        },
        {
          "command": "dotnav.ef.addMigration",
          "when": "view == dotnav.efCore && (viewItem == efProject || viewItem == efContext)",
          "group": "1_migrations@1"
        },
        {
          "command": "dotnav.ef.removeLastMigration",
          "when": "view == dotnav.efCore && (viewItem == efProject || viewItem == efContext)",
          "group": "1_migrations@2"
        },
        {
          "command": "dotnav.ef.updateDatabase",
          "when": "view == dotnav.efCore && (viewItem == efProject || viewItem == efContext)",
          "group": "2_database@1"
        },
        {
          "command": "dotnav.ef.updateDatabaseTo",
          "when": "view == dotnav.efCore && viewItem == efContext",
          "group": "2_database@2"
        },
        {
          "command": "dotnav.ef.generateScript",
          "when": "view == dotnav.efCore && viewItem == efContext",
          "group": "2_database@3"
        },
        {
          "command": "dotnav.ef.dbContextInfo",
          "when": "view == dotnav.efCore && viewItem == efContext",
          "group": "2_database@4"
        },
        {
          "command": "dotnav.ef.selectStartupProject",
          "when": "view == dotnav.efCore && viewItem == efProject",
          "group": "3_manage@1"
        },
        {
          "command": "dotnav.ef.openCsproj",
          "when": "view == dotnav.efCore && viewItem == efProject",
          "group": "3_manage@2"
        },
        {
          "command": "dotnav.ef.refresh",
          "when": "view == dotnav.efCore && (viewItem == efProject || viewItem == efContext)",
          "group": "3_manage@3"
        },
        {
          "command": "dotnav.ef.dropDatabase",
          "when": "view == dotnav.efCore && viewItem == efContext",
          "group": "9_danger@1"
        },
        {
          "command": "dotnav.ef.openMigrationFile",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigration/",
          "group": "1_open@1"
        },
        {
          "command": "dotnav.ef.copyMigrationName",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigration/",
          "group": "1_open@2"
        },
        {
          "command": "dotnav.ef.updateDatabaseToThis",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigration(Pending|Unknown)/",
          "group": "2_database@1"
        },
        {
          "command": "dotnav.ef.rollbackDatabaseToThis",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigrationApplied/",
          "group": "2_database@1"
        },
        {
          "command": "dotnav.ef.generateScriptFromThis",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigration/",
          "group": "2_database@2"
        },
        {
          "command": "dotnav.ef.removeLastMigration",
          "when": "view == dotnav.efCore && viewItem =~ /^efMigration.*Last$/",
          "group": "3_remove@1"
        }
      ],
      "commandPalette": [
        {
          "command": "dotnav.ef.updateDatabaseToThis",
          "when": "false"
        },
        {
          "command": "dotnav.ef.rollbackDatabaseToThis",
          "when": "false"
        },
        {
          "command": "dotnav.ef.generateScriptFromThis",
          "when": "false"
        },
        {
          "command": "dotnav.ef.openMigrationFile",
          "when": "false"
        },
        {
          "command": "dotnav.ef.copyMigrationName",
          "when": "false"
        },
        {
          "command": "dotnav.ef.openCsproj",
          "when": "false"
        }
      ],
      "dotnav.add": [
        {
          "command": "dotnav.addClass",
          "group": "1_new@1"
        },
        {
          "command": "dotnav.addInterface",
          "group": "1_new@2"
        },
        {
          "command": "dotnav.addRecord",
          "group": "1_new@3"
        },
        {
          "command": "dotnav.addEnum",
          "group": "1_new@4"
        },
        {
          "command": "dotnav.addFile",
          "group": "2_file@1"
        },
        {
          "command": "dotnav.addFolder",
          "group": "2_file@2"
        },
        {
          "command": "dotnav.addExistingItem",
          "group": "3_existing@1"
        }
      ],
      "dotnav.project": [
        {
          "command": "dotnav.setStartupProject",
          "group": "1_project@1"
        },
        {
          "command": "dotnav.openProjectFile",
          "group": "1_project@2"
        },
        {
          "command": "dotnav.openTerminalHere",
          "group": "2_open@1"
        },
        {
          "command": "dotnav.revealInOs",
          "group": "2_open@2"
        }
      ],
      "dotnav.copy": [
        {
          "command": "dotnav.copyPath",
          "group": "1_copy@1"
        },
        {
          "command": "dotnav.copyRelativePath",
          "group": "1_copy@2"
        }
      ]
    },
    "configuration": {
      "title": "DotNav",
      "properties": {
        "dotnav.ef.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the EF Core tools (detection, tree view, and commands)."
        },
        "dotnav.ef.startupProject": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative path to the csproj used as --startup-project for EF commands. Leave empty to auto-detect."
        },
        "dotnav.ef.configuration": {
          "type": "string",
          "default": "Debug",
          "description": "Build configuration passed to dotnet ef (--configuration)."
        },
        "dotnav.ef.noBuild": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "Skip the build when DotNav knows the project output is fresh; retry with a build on failure.",
            "Always pass --no-build (fastest, but you must build yourself).",
            "Always let dotnet ef build (slowest, safest)."
          ],
          "default": "auto",
          "description": "Controls when EF commands pass --no-build."
        },
        "dotnav.ef.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Pass --verbose to dotnet ef and log full output."
        },
        "dotnav.ef.checkPendingOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Discover EF projects and DbContexts as soon as the workspace opens instead of lazily."
        },
        "dotnav.ef.migrationsSortOrder": {
          "type": "string",
          "enum": [
            "oldestFirst",
            "newestFirst"
          ],
          "default": "oldestFirst",
          "description": "Order of migrations in the EF Core tree."
        },
        "dotnav.ef.environmentVariables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Environment variables passed to dotnet ef processes (e.g. ASPNETCORE_ENVIRONMENT)."
        },
        "dotnav.ef.commandTimeout": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "Seconds before a running EF command prompts to keep waiting or kill the process."
        },
        "dotnav.hiddenFolders": {
          "type": "array",
          "default": [
            "bin",
            "obj",
            ".vs",
            ".vscode",
            ".git",
            ".idea",
            ".config",
            "node_modules",
            "TestResults",
            "coverage",
            "artifacts",
            "packages"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names hidden from the solution tree."
        },
        "dotnav.hiddenFiles": {
          "type": "array",
          "default": [
            "*.user",
            "*.suo",
            "*.cache"
          ],
          "items": {
            "type": "string"
          },
          "description": "File globs hidden from the solution tree."
        },
        "dotnav.showDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Show project and NuGet dependencies under each project."
        },
        "dotnav.nuget.includePrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Include prerelease versions in NuGet package searches and version pickers."
        },
        "dotnav.showProjectFiles": {
          "type": "boolean",
          "default": true,
          "description": "Show project files such as .csproj, .fsproj, .vbproj, and .dcproj inside each project node."
        },
        "dotnav.buildBeforeRun": {
          "type": "boolean",
          "default": true,
          "description": "Build the selected project before running or debugging it."
        },
        "dotnav.buildConfiguration": {
          "type": "string",
          "enum": [
            "Debug",
            "Release"
          ],
          "default": "Debug",
          "description": "Build configuration used when running or debugging projects."
        },
        "dotnav.buildTimeoutSeconds": {
          "type": "number",
          "default": 600,
          "minimum": 1,
          "description": "Maximum time in seconds to wait for a build before marking the run as failed."
        },
        "dotnav.maxParallelBuilds": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "description": "Maximum number of MSBuild workers used by Build Projects in Folder."
        },
        "dotnav.startTimeoutSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Maximum time in seconds to wait for a debug or run session to start."
        },
        "dotnav.forceKillTaskOnStopTimeout": {
          "type": "boolean",
          "default": true,
          "description": "Force-kill the tracked task PID after Stop times out. On Windows this kills the owned process tree."
        },
        "dotnav.iconMode": {
          "type": "string",
          "enum": [
            "auto",
            "rider",
            "theme",
            "minimal"
          ],
          "default": "auto",
          "description": "Icon style used by the .NET solution tree. Auto combines Rider project/special-folder icons with the active file icon theme."
        },
        "dotnav.enableFileNesting": {
          "type": "boolean",
          "default": true,
          "description": "Nest related files under parent files in the .NET solution tree."
        },
        "dotnav.alwaysSelectOpenedFile": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reveal the active editor file in the .NET solution tree."
        },
        "dotnav.format.normalizeIndentWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "Normalize leading indentation to the active indentation unit before applying C# house-style passes."
        },
        "dotnav.format.enableLeadingComma": {
          "type": "boolean",
          "default": true,
          "description": "Format multiline C# parameter and argument lists with leading commas."
        },
        "dotnav.format.wrapColumn": {
          "type": "number",
          "default": 120,
          "minimum": 40,
          "description": "Fallback line width for C# wrapping. A matching .editorconfig max_line_length takes precedence."
        },
        "dotnav.format.leadingCommaWrapStyle": {
          "type": "string",
          "enum": [
            "wrapIfLong",
            "chopAlways",
            "keep"
          ],
          "default": "wrapIfLong",
          "description": "Controls wrapping of single-line C# parameter and argument lists; existing multiline leading commas are always normalized."
        },
        "dotnav.format.enableFluentChainWrap": {
          "type": "boolean",
          "default": true,
          "description": "Normalize indentation for multiline fluent and LINQ chains."
        },
        "dotnav.format.fluentChainMinSegments": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Minimum number of dot-prefixed continuation lines before they are aligned to the same indentation level."
        },
        "dotnav.format.enableBlankLineRules": {
          "type": "boolean",
          "default": true,
          "description": "Collapse repeated blank lines and remove blank lines immediately inside braces."
        },
        "dotnav.format.expandToEnclosingMember": {
          "type": "boolean",
          "default": false,
          "description": "Expand Format Selection to the enclosing C# member. Disabled by default so formatting only changes the selected lines."
        },
        "dotnav.fileNestingRules": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "parentPattern": {
                "type": "string"
              },
              "childPattern": {
                "type": "string"
              }
            },
            "required": [
              "parentPattern",
              "childPattern"
            ]
          },
          "description": "Additional file nesting rules. Use ${base} in parentPattern and childPattern."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies"
  }
}
